# BigBrother Environment Configuration

# Database
DATABASE_URL=postgresql://bigbrother:bigbrother@localhost:5432/bigbrother

# Server
PORT=3000
LOG_LEVEL=info

# Docker
SANDBOX_IMAGE_NAME=bigbrother-sandbox
SANDBOX_TIMEOUT_MS=300000

# Upload
MAX_UPLOAD_SIZE_MB=500

# Storage
ARTIFACT_STORAGE_PATH=./storage/artifacts
